+import { Project } from '../model/types';
+import { projectFromJSON, projectToJSON } from '../model/schema';
+
+export function exportProject(project: Project): string {
+  return projectToJSON(project);
+}
+
+export function importProject(json: string): { ok: true; project: Project } | { ok: false; err: string } {
+  return projectFromJSON(json);
+}
+
+// Helper to download a project as a file (for UI usage)
+export function downloadProjectFile(project: Project, filename = 'project.json') {
+  const blob = new Blob([exportProject(project)], { type: 'application/json' });
+  const url = URL.createObjectURL(blob);
+  const a = document.createElement('a');
+  a.href = url;
+  a.download = filename;
+  document.body.appendChild(a);
+  a.click();
+  a.remove();
+  URL.revokeObjectURL(url); 
+}

