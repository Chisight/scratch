+import { Pin, PrimitiveInstance } from '../model/types';
+
+type ValidationResult = { ok: true } | { ok: false; reason: string };
+
+// Determine if a connection between two pins is allowed.
+// Rules:
+// - connecting two outputs is an error unless both are tristate pins.
+// - other combos are allowed.
+export function validateConnection(pinA: Pin | undefined, pinB: Pin | undefined): ValidationResult {
+  if (!pinA || !pinB) return { ok: false, reason: 'missing pin' };
+  // normalize direction
+  const dA = pinA.direction;
+  const dB = pinB.direction;
+  // if both are outputs
+  const isOutputA = dA === 'output';
+  const isOutputB = dB === 'output';
+  if (isOutputA && isOutputB) {
+    // allow if both are tristate (i.e., direction 'tristate' would not be 'output')
+    return { ok: false, reason: 'cannot connect two outputs' };
+  }
+  // output + tristate is allowed
+  // tristate + tristate allowed
+  return { ok: true };
+}
+
+// Helper to find pin by id from instance list
+export function findPinById(instances: PrimitiveInstance[], pinId: string): Pin | undefined {
+  for (const inst of instances) {
+    for (const p of inst.pins) {
+      if (p.id === pinId) return p;
+    }
+  }
+  return undefined;
+}
