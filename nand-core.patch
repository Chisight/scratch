+import { Workspace, Wire, Net, Pin, PrimitiveInstance } from '../model/types';
+
+// Compute nets from workspace wires and pins.
+// Simple algorithm:
+// - Each wire belongs to a net. Wires that share a pin or intersect at a pin combine into a net.
+// - For now, we only consider explicit pin attachments: wires list pins connected to them.
+// - A net is group of wires and pins that are transitively connected via shared pins.
+
+export function computeNets(workspace: Workspace): Net[] {
+  const wires = workspace.wires;
+  const instances = workspace.instances;
+  // Build map wireId -> set of pinIds
+  const wireToPins = new Map<string, Set<string>>();
+  for (const w of wires) {
+    wireToPins.set(w.id, new Set(w.pins));
+  }
+  // Union-find over wires via pins
+  const wireIndex = new Map<string, number>();
+  for (let i = 0; i < wires.length; i++) wireIndex.set(wires[i].id, i);
+  const parent = new Array(wires.length).fill(0).map((_, i) => i);
+  function find(a: number): number {
+    if (parent[a] === a) return a;
+    parent[a] = find(parent[a]);
+    return parent[a];
+  }
+  function union(a: number, b: number) {
+    const pa = find(a);
+    const pb = find(b);
+    if (pa === pb) return;
+    parent[pb] = pa;
+  }
+  // Map pinId -> wire indices that reference it
+  const pinToWireIdx = new Map<string, number[]>();
+  for (let i = 0; i < wires.length; i++) {
+    const w = wires[i];
+    for (const pid of w.pins) {
+      const arr = pinToWireIdx.get(pid) || [];
+      arr.push(i);
+      pinToWireIdx.set(pid, arr);
+    }
+  }
+  // Union wires that share pins
+  for (const [, wireIdxs] of pinToWireIdx.entries()) {
+    for (let i = 1; i < wireIdxs.length; i++) {
+      union(wireIdxs[0], wireIdxs[i]);
+    }
+  }
+  // Build groups
+  const groups = new Map<number, { wireIds: string[]; pinIds: Set<string> }>();
+  for (let i = 0; i < wires.length; i++) {
+    const root = find(i);
+    const g = groups.get(root) || { wireIds: [], pinIds: new Set<string>() };
+    g.wireIds.push(wires[i].id);
+    for (const pid of wires[i].pins) g.pinIds.add(pid);
+    groups.set(root, g);
+  }
+  // Create nets
+  const nets: Net[] = [];
+  let counter = 0;
+  for (const g of groups.values()) {
+    nets.push({
+      id: `net:${counter++}`,
+      wireIds: g.wireIds as Wire['id'][],
+      pinIds: Array.from(g.pinIds) as Pin['id'][]
+    });
+  }
+  // Also include isolated pins (pins attached to no wire) as single-pin nets
+  const allPinIds = new Set<string>();
+  for (const inst of instances) for (const p of inst.pins) allPinIds.add(p.id);
+  const referencedPins = new Set<string>();
+  for (const n of nets) for (const p of n.pinIds) referencedPins.add(p);
+  for (const pid of allPinIds) {
+    if (!referencedPins.has(pid)) {
+      nets.push({ id: `net:${counter++}`, wireIds: [], pinIds: [pid] });
+    }
+  }
+  return nets;
+}
+
+// Helper: map pinId -> netId
+export function pinToNetMap(nets: Net[]): Map<string, string> {
+  const m = new Map<string, string>();
+  for (const n of nets) {
+    for (const pid of n.pinIds) {
+      m.set(pid, n.id);
+    }
+  }
+  return m;
+}
+
