+// Small typed-id helpers
+export type ID<T extends string> = `${T}:${string}`;
+
+function randomHex(len = 8) {
+  let s = '';
+  const hex = '0123456789abcdef';
+  for (let i = 0; i < len; i++) s += hex[Math.floor(Math.random() * 16)];
+  return s;
+}
+
+export function makeId<T extends string>(prefix: T): ID<T> {
+  return `${prefix}:${Date.now().toString(36)}${randomHex(6)}` as ID<T>;
+}
+
+// Common typed ids
+export type ChipId = ID<'chip'>;
+export type InstanceId = ID<'inst'>;
+export type WireId = ID<'wire'>;
+export type PinId = ID<'pin'>;
+export type NetId = ID<'net'>;
+
