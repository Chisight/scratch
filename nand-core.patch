+import { Project } from './types';
+
+const CURRENT_VERSION = 1;
+
+export function projectToJSON(project: Project): string {
+  const payload = { version: CURRENT_VERSION, project };
+  return JSON.stringify(payload);
+}
+
+export function projectFromJSON(
+  json: string
+): { ok: true; project: Project } | { ok: false; err: string } {
+  try {
+    const parsed = JSON.parse(json);
+    if (!parsed || typeof parsed !== 'object') return { ok: false, err: 'invalid json' };
+    if (parsed.version !== CURRENT_VERSION) return { ok: false, err: 'unsupported version' };
+    if (!parsed.project) return { ok: false, err: 'no project payload' };
+    // Minimal runtime validation
+    const p = parsed.project as Project;
+    if (!p.workspace) return { ok: false, err: 'missing workspace' };
+    return { ok: true, project: p };
+  } catch (e) {
+    return { ok: false, err: (e as Error).message };
+  }
+}
