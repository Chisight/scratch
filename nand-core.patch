+// Basic geometry
+export type Point = { x: number; y: number };
+
+// Pin direction categories
+export type PinDirection =
+  | 'input'
+  | 'output'
+  | 'tristate'
+  | 'addr'
+  | 'we'
+  | 'en'
+  | 'clock'
+  | 'power';
+
+export type Pin = {
+  id: PinId;
+  name?: string;
+  direction: PinDirection;
+  // Instance-local pin index (0-based)
+  index: number;
+  // For layout
+  pos: Point;
+};
+
+export type PrimitiveType =
+  | 'NAND'
+  | 'TRISTATE'
+  | 'RAM'
+  | 'CLOCK'
+  | 'CONST0'
+  | 'IO8'
+  | 'IO1'
+  | 'CHIP';
+
+export type PrimitiveInstance = {
+  id: InstanceId;
+  type: PrimitiveType | ChipId;
+  name?: string;
+  pos: Point;
+  pins: Pin[];
+  // metadata for primitives (e.g., RAM address pin count)
+  meta?: Record<string, unknown>;
+};
+
+export type Wire = {
+  id: WireId;
+  points: Point[]; // waypoints; endpoints connect to pin positions
+  // attached pins (0..n). pins array ordered
+  pins: PinId[];
+};
+
+export type Net = {
+  id: string;
+  wireIds: WireId[];
+  pinIds: PinId[];
+};
+
+export type Workspace = {
+  id: string;
+  name?: string;
+  instances: PrimitiveInstance[];
+  wires: Wire[];
+};
+
+export type Chip = {
+  id: ChipId;
+  name: string;
+  workspace: Workspace; // snapshot of the chip internals
+  createdAt: number;
+};
+
+export type Project = {
+  version: number;
+  chips: Chip[];
+  workspace: Workspace;
+};
+
+// Serialization helper minimal interface
+export function shallowCloneWorkspace(ws: Workspace): Workspace {
+  return {
+    id: ws.id,
+    name: ws.name,
+    instances: ws.instances.map((i) => ({ ...i, pins: i.pins.map((p) => ({ ...p })) })),
+    wires: ws.wires.map((w) => ({ ...w, points: w.points.map((pt) => ({ ...pt })) }))
+  };
+}
